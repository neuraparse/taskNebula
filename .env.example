# ============================================
# TaskNebula - Environment Variables
# Copy this file to .env and fill in the values
# cp .env.example .env
# ============================================

# ===========================================
# REQUIRED SETTINGS
# ===========================================

# Database Connection
# For Docker Compose, use the default values below
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/tasknebula

# Redis Connection
REDIS_URL=redis://redis:6379

# Auth.js Secret Key (minimum 32 characters)
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-super-secret-key-at-least-32-characters

# Application URLs
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application Name
NEXT_PUBLIC_APP_NAME=TaskNebula

# ===========================================
# OPTIONAL - OAuth Providers
# ===========================================

# GitHub OAuth
# Create app at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
# Create app at: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# OPTIONAL - AI/LLM Integration
# ===========================================

# OpenAI API Key
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ===========================================
# PRODUCTION SETTINGS
# ===========================================

# Node Environment
NODE_ENV=production

# ===========================================
# DEMO ACCOUNTS (Auto-created on first run)
# ===========================================
# All demo accounts use password: demo123
#
# - admin@tasknebula.io (Super Admin)
# - po@tasknebula.io (Product Owner)
