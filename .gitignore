# ============================================================================
# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
.Trash-*
.fuse_hidden*
.nfs*

# ============================================================================
# ARCHIVES (usually binary junk or backups)
# ============================================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.tar.xz
*.txz
*.tar.bz2
*.tbz2
*.7z
*.rar
*.iso
*.dmg

# ============================================================================
# TEMP / CACHE / WORKING FILES
# ============================================================================
tmp/
temp/
.tmp/
.temp/
*.tmp
*.temp
*.stackdump
*.orig.*
*.rej
*.patch.bak
*.swp.bak
scratch/
.scratch/
sandbox/
.playground/

# Python (if any Python scripts creep in)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Rust
target/
!src/target/
Cargo.lock.bak

# ============================================================================
# MEDIA / BINARY ASSETS (allow-list via exceptions below if needed)
# ============================================================================
# Large raw media that doesn't belong in git (use LFS or external storage)
*.mov
*.mp4
*.m4v
*.avi
*.mkv
*.webm
*.flv
*.wmv
# Audio
*.wav
*.aiff
*.flac
*.m4a
# Large images
*.psd
*.ai
*.sketch
*.fig
# PDFs (enable if docs need them)
# *.pdf

# ============================================================================
# PROJECT-SPECIFIC (TaskNebula)
# ============================================================================
# Uploads directory contents (keep placeholder)
apps/web/uploads/*
!apps/web/uploads/.gitkeep

# Forensic incident artifacts (binary malware samples / large logs)
forensic/

# Operator notes and drafts
todo.txt
TODO.local.md
NOTES.md
NOTES.local.md

# Deployment-specific nginx vhosts bearing real domains. Keep real domains
# out of the repo — add your own host's pattern locally if needed.
nginx/*.your-domain.*
nginx/*.example.com*
nginx/*.live.*
nginx/sites-*.local/

# Internal generated scripts or data
packages/db/scripts/setup-api-platform-docs.ts

# ============================================================================
# MISC / FALLBACKS
# ============================================================================
# Editor swap/backups
*.bak
*.backup*
*.autosave
*.recovery

# Mac resource forks
._*

# Git merge leftovers
*.orig

# Lock files from tools you don't use (keep your package manager's, ignore others)
# package-lock.json    # <-- ignore if you use pnpm/yarn (uncomment)
# yarn.lock            # <-- ignore if you use pnpm (uncomment)

# Local JSON dumps / exports users may create
export.json
export-*.json
exports/
data-dump/
*.csv.local
*.xlsx.local

# Local UI audit screenshots — never commit
.ui-audit/

# Local scratch/diagnostic scripts — never commit
apps/web/_*.mjs

# Mobile app (TaskNebula Mobile) — PRIVATE, NOT open-source / community.
# Lives outside the pnpm/turbo workspace so it can never affect the web build.
# The entire directory is intentionally untracked — never commit it.
/mobile/
