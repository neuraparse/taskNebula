# ============================================
# TaskNebula - Open Source .gitignore
# ============================================

# ===========================================
# DEPENDENCIES
# ===========================================
node_modules/
.pnp
.pnp.js

# ===========================================
# BUILD OUTPUTS
# ===========================================
.next/
out/
build/
dist/
.turbo/

# ===========================================
# ENVIRONMENT & SECRETS
# ===========================================
.env
.env.local
.env*.local
.env.development.local
.env.test.local
.env.production.local

# SSL Certificates
nginx/ssl/
*.pem
*.key
*.crt
*.p12

# ===========================================
# TESTING
# ===========================================
coverage/
.nyc_output

# ===========================================
# IDE & OS
# ===========================================

# VS Code
.vscode/

# JetBrains
.idea/

# Vim/Neovim
*.swp
*.swo
*~

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# ===========================================
# LOGS & DEBUG
# ===========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ===========================================
# MISC
# ===========================================

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel

# Temporary files
tmp/
temp/
*.tmp

# Claude
.claude

# Docker volumes
postgres_data/
redis_data/
uploads_data/

# Backup files
*.backup*

# Upload files
apps/web/uploads/*
!apps/web/uploads/.gitkeep
docker-compose.override.yml
todo.txt
packages/db/scripts/setup-api-platform-docs.ts
forensic/

# ===========================================
# LOCAL / DEPLOYMENT-SPECIFIC OVERRIDES
# ===========================================

# Any file ending with .local (lets users keep local variants side-by-side)
*.local
*.local.*

# Secrets / credential files
secrets/
.secrets
.secrets.*
*.secret
*.secrets.json
.pgpass
.netrc
.htpasswd

# SSH keys (any form)
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.pub.backup
known_hosts.backup

# Direnv / asdf / nvm local
.envrc
.tool-versions.local
.nvmrc.local

# Docker compose overrides (keep base docker-compose.yml only)
docker-compose.*.override.yml
docker-compose.local.yml
docker-compose.prod.yml
docker-compose.staging.yml
docker-compose.personal.yml

# User-customized nginx vhost files (keep nginx/tasknebula.conf as template)
nginx/sites-available/
nginx/sites-enabled/
nginx/*.local.conf
nginx/*-local.conf
nginx/*.personal.conf
nginx/conf.d/
# Real deployment vhosts should be named with your domain and ignored:
nginx/*.nowflow.io*
nginx/*.your-domain.*

# Database dumps / backups
*.dump
*.dump.gz
*.sql.gz
*.sqlite
*.sqlite3
*.db
pg-backup/
pg-backups/
db-backups/

# Let's Encrypt / Certbot staging
letsencrypt/
certbot/

# CI / deployment configs that include project-specific bits
.terraform/
*.tfvars
*.tfstate
*.tfstate.backup
ansible/vault_pass
.vault_pass*

# Editor/AI caches
.cursor/
.aider*
.continue/
.windsurf/

# OS-level extra
.Spotlight-V100
.Trashes
ehthumbs.db

# Local notes & drafts
NOTES.md
NOTES.local.md
scratch/
.scratch/
