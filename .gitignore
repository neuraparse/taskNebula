# ============================================================================
# TaskNebula — Comprehensive .gitignore
# Covers: secrets/credentials, env, build, logs, caches, IDE/AI, DBs, certs,
# archives, OS junk, deployment overrides, IaC state, profiling, media, etc.
# Keep this list alphabetically grouped within sections where practical.
# ============================================================================

# ============================================================================
# DEPENDENCIES (package managers)
# ============================================================================
node_modules/
.pnp
.pnp.js
.pnp.cjs
.pnp.loader.mjs
.yarn/cache/
.yarn/install-state.gz
.yarn/unplugged/
.yarn/build-state.yml
.pnpm-store/
.pnpm-debug.log*
.npm/
.bun/
bun.lockb.local
jspm_packages/
bower_components/
vendor/
.venv/
venv/
env/
.virtualenv/
__pypackages__/

# ============================================================================
# BUILD & COMPILED OUTPUTS
# ============================================================================
.next/
out/
build/
dist/
.turbo/
.cache/
.parcel-cache/
.rollup.cache/
.svelte-kit/
.nuxt/
.docusaurus/
.astro/
.remix/
.expo/
.expo-shared/
.gatsby/
public/build/
storybook-static/
.storybook-out/
*.tsbuildinfo
next-env.d.ts

# ============================================================================
# ENVIRONMENT & SECRETS (credentials never-commit zone)
# ============================================================================
# Env files — all variants
.env
.env.*
!.env.example
!.env.template
!.env.sample
!.env.defaults
.envrc
.env.backup
.env.old

# Any file ending in .local (override files)
*.local
*.local.*

# Secret-bearing files by naming convention
secrets/
.secrets
.secrets.*
*.secret
*.secrets
*.secrets.json
secret.json
secret.yaml
secret.yml
credentials
credentials.json
credentials.yaml
credentials.yml
.credentials
.credentials.json
*.credentials.json
auth.json
.auth
*.auth.json

# Unix credential stores
.pgpass
.netrc
.my.cnf
.htpasswd
.htaccess.local
.boto

# SSH keys (never commit private keys)
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
id_dsa
id_dsa.*
*.rsa
*.pub.backup
known_hosts.backup
authorized_keys.backup

# TLS / X.509 / PKI
*.pem
*.key
*.keystore
*.jks
*.p12
*.pfx
*.crt
*.cer
*.der
*.csr
*.pkcs12
*.gpg
*.asc
*.age
*.enc
nginx/ssl/
certs/
certificates/
letsencrypt/
certbot/
acme.json

# API keys / tokens (common patterns)
*.token
*.apikey
*_rsa
*_ed25519
.aws/
.gcp/
.azure/
.doctl/
.digitalocean/
.kube/config
kubeconfig
kubeconfig.*

# Vault / Ansible secrets
.vault_pass
.vault_pass.*
ansible/vault_pass
ansible/vault.yml
vault.yml

# ============================================================================
# DATABASE DUMPS & BACKUPS (may contain PII/credentials)
# ============================================================================
*.dump
*.dump.gz
*.dump.xz
*.dump.bz2
*.sql
!drizzle/**/*.sql
!packages/db/drizzle/**/*.sql
!docker/postgres/init.sql
*.sql.gz
*.sql.xz
*.sql.bz2
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
*.sqlite3
*.db
*.db-journal
*.mdb
*.bak
*.backup
*.backup.*
*.old
*.orig
pg-backup/
pg-backups/
db-backup/
db-backups/
postgres-backup/
mysql-backup/
dumps/
backups/

# Docker managed volumes (local mount-point safety)
postgres_data/
redis_data/
uploads_data/

# ============================================================================
# DEPLOYMENT / INFRA OVERRIDES
# ============================================================================
# Docker
docker-compose.override.yml
docker-compose.*.override.yml
docker-compose.local.yml
docker-compose.prod.yml
docker-compose.staging.yml
docker-compose.dev.local.yml
docker-compose.personal.yml
docker-compose.private.yml
.dockerignore.local

# Nginx user-customized vhosts (keep nginx/tasknebula.conf as template)
nginx/sites-available/
nginx/sites-enabled/
nginx/conf.d/
nginx/*.local.conf
nginx/*-local.conf
nginx/*.personal.conf
nginx/*.private.conf
nginx/*.deploy.conf

# Terraform / OpenTofu
.terraform/
.terraform.lock.hcl
*.tfvars
*.tfvars.json
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraformrc
crash.log
crash.*.log

# Pulumi
Pulumi.*.yaml
!Pulumi.yaml
.pulumi/

# Serverless / SST / CDK
.serverless/
.sst/
.sst.cache/
cdk.out/
cdk.context.json

# Helm / Kubernetes local values
*.values.local.yaml
*.values.local.yml
values.local.yaml
values.local.yml
charts/*/charts/
*.tgz
!docs/**/*.tgz

# Ansible
*.retry
ansible/*.log

# Cloud CLI local state
.vercel
.netlify
.fly/
.railway/
.render/
.supabase/

# ============================================================================
# LOGS & DEBUG
# ============================================================================
*.log
!**/CHANGELOG*.md
logs/
log/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
bun-debug.log*
*.pid
*.pid.lock
*.seed
*.crash
*.rpt
*.trace

# Profiling / heap dumps
*.heapsnapshot
*.heapprofile
*.cpuprofile
*.trace.json
v8-*.log
isolate-*.log
*.prof

# Test/coverage outputs
coverage/
.nyc_output/
.coverage
htmlcov/
junit.xml
test-results/
playwright-report/
playwright/.cache/
apps/web/e2e/.auth/
cypress/videos/
cypress/screenshots/
cypress/downloads/
.jest-cache/

# ============================================================================
# IDE / EDITORS
# ============================================================================
# JetBrains (IntelliJ, WebStorm, PyCharm, etc.)
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# VS Code
.vscode/
!.vscode/settings.shared.json
.history/
.vscode-test/

# Cursor — share rules (team config), ignore personal/local config
.cursor/*
!.cursor/rules/
.cursorrules.local

# Zed
.zed/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/

# TextMate
*.tmproj
*.tmproject
tmtags

# Eclipse
.project
.classpath
.settings/
.factorypath

# NetBeans
nbproject/
nbbuild/
nbdist/

# Vim / Neovim
*.swp
*.swo
*.swn
*~
.vimrc.local
.nvimrc.local
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.\#*
.elc
.emacs.desktop
.emacs.desktop.lock
auto-save-list/
tramp

# Helix
.helix/

# Kate
*.kate-swp

# Fleet
.fleet/

# ============================================================================
# AI / LLM TOOLING
# ============================================================================
# Claude Code — share team config (settings.json, agents, commands, rules),
# ignore personal/local files and generated worktrees.
.claude/*
!.claude/settings.json
!.claude/agents/
!.claude/commands/
!.claude/rules/
!.claude/output-styles/
.claude/settings.local.json
.claude/worktrees/
# Personal/local variants must never be published, even inside shared dirs.
.claude/**/*.local.json
.claude/**/*.local.md
**/CLAUDE.local.md
.claude/memory/
.anthropic/

# Cursor / Aider / Continue / Cody / Windsurf / etc.
.aider*
.aider.conf.yml.local
.continue/
.windsurf/
.codeium/
.cody/
.tabnine/
.gh-copilot/
.github-copilot/
.codewhisperer/

# OpenAI project files
openai.yaml.local
.openai/
.openai.local

# LLM chat exports / transcripts
*.chat.md
transcripts/
conversations/

# ============================================================================
