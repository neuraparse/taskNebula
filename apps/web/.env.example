# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tasknebula

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# OAuth Providers (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI / LLM (for future use)
OPENAI_API_KEY=

# Jira (Atlassian) OAuth 3LO — https://developer.atlassian.com/console/myapps/
# Create an OAuth 2.0 (3LO) app and add the callback URL below to its redirect list.
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:3000/api/integrations/jira/callback

