# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tasknebula

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# OAuth Providers (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI / LLM (for future use)
OPENAI_API_KEY=

# Integrations — Slack OAuth
# Create a Slack app at https://api.slack.com/apps, then set the following.
# SLACK_REDIRECT_URI must exactly match the "Redirect URL" registered in Slack.
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_REDIRECT_URI=http://localhost:3000/api/integrations/slack/callback

