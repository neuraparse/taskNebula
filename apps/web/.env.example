# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tasknebula

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# OAuth Providers (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Integrations — GitLab OAuth
# Create an application at https://gitlab.com/-/user_settings/applications
# Redirect URI must exactly match GITLAB_REDIRECT_URI below.
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://localhost:3000/api/integrations/gitlab/callback
# Optional override (defaults to "read_api read_repository")
GITLAB_OAUTH_SCOPE=

# AI / LLM (for future use)
OPENAI_API_KEY=

